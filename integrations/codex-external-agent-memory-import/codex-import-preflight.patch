+fn verify_canonical_fixture(fixture: &str) -> io::Result<String> {
+    let repository_root = std::env::var_os("CMV_REPOSITORY_ROOT")
+        .map(PathBuf::from)
+        .ok_or_else(|| invalid_data_error("CMV_REPOSITORY_ROOT is required"))?;
